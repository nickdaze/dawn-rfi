# Copy this file to `.env` and fill in your real values.
# `.env` is gitignored and must NEVER be committed. This template is safe to commit.
#
# From a Dev Dashboard app (legacy custom apps can't be created after Jan 1, 2026):
#   Shopify admin → Settings → Apps and sales channels → Develop apps →
#   "Build apps in Dev Dashboard" → create app → configure Admin API scope
#   write_content → install on this store → app Settings → copy Client credentials.
# The script exchanges these for a short-lived (24h) access token at runtime,
# so there is no long-lived token to store.
SHOPIFY_CLIENT_ID=your_client_id
SHOPIFY_CLIENT_SECRET=your_client_secret

# Store domain (scripts already default to this; override only if needed)
SHOPIFY_STORE=42d600-71.myshopify.com
